        "list":
        [
            {
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402335}",
                "name": "PS Core / GitHub",
                "commandline": "pwsh.exe",
                "startingDirectory": "%USERPROFILE%\\Documents\\Development\\source\\GitHub",
                "icon": "%USERPROFILE%\\Documents\\Development\\PowerShell_Core_6.0_icon.png"
            },
            {
                // Use Code.exe via PATH because Copilot CLI on Windows does not reliably handle code.cmd as external editor - see https://github.com/github/copilot-cli/issues/1882
                "environment": 
                {
                    "PATH": "C:\\Program Files\\Microsoft VS Code;%PATH%",
                    "EDITOR": "Code.exe --wait",
                    "VISUAL": "Code.exe --wait"
                    // If you use a company proxy, uncomment these entries and run px proxy locally.
                    // ,"NODE_USE_ENV_PROXY": "1"
                    // ,"NODE_USE_SYSTEM_CA": "1"
                    // ,"HTTPS_PROXY": "http://localhost:3128"
                    // ,"HTTP_PROXY": "http://localhost:3128"
                },
                "commandline": "copilot",
